#!/usr/bin/env python3

from __future__ import annotations

import datetime as _datetime
import json
import os
import re
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any, Callable


AUTO_COMMIT = os.environ.get("AUTO_COMMIT", "1")
BUILD_AFTER_UPDATE = os.environ.get("BUILD_AFTER_UPDATE", "1")
GITHUB_API = os.environ.get("GITHUB_API", "https://api.github.com").rstrip("/")


class UpdateError(Exception):
    pass


def usage() -> str:
    return """Usage:
  ./manual-packages/update
  ./manual-packages/update --all
  ./manual-packages/update <package>

Or from repo root:
  ./update manual
  ./update manual --all
  ./update manual <package>

Default:
  no argument means --all

Environment:
  AUTO_COMMIT=0          Do not commit changes
  BUILD_AFTER_UPDATE=0   Do not build after update
  GITHUB_TOKEN=...       Optional GitHub token for higher GitHub API rate limit

Per-package options:
  By default, the updater follows the repository's GitHub default branch.
  Add this comment near the top of a package file to track a different branch:

    # update-branch: master
"""


def run(
    args: list[str],
    *,
    capture: bool = False,
    check: bool = True,
    stderr_to_stdout: bool = False,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        check=check,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.STDOUT if stderr_to_stdout else None,
    )


def run_stdout(args: list[str]) -> str:
    return run(args, capture=True).stdout.strip()


def repo_root() -> Path:
    return Path(run_stdout(["git", "rev-parse", "--show-toplevel"]))


def manual_package_names() -> list[str]:
    system = run_stdout(["nix", "eval", "--impure", "--raw", "--expr", "builtins.currentSystem"])
    raw_names = run_stdout(["nix", "eval", "--json", f".#lib.{system}.manualPackageNames"])
    names = json.loads(raw_names)

    if not isinstance(names, list) or not all(isinstance(name, str) for name in names):
        raise UpdateError("Unexpected manual package name list from nix eval")

    return names


def package_file_for(pkg: str) -> Path:
    flat_file = Path("manual-packages") / f"{pkg}.nix"
    nested_file = Path("manual-packages") / pkg / "package.nix"

    if flat_file.is_file():
        return flat_file
    if nested_file.is_file():
        return nested_file

    raise UpdateError(f"Cannot find package file for manual package: {pkg}")


def github_api_get_json(url: str) -> Any:
    headers = {
        "Accept": "application/vnd.github+json",
        "User-Agent": "emacs-overlay-manual-package-updater",
    }

    token = os.environ.get("GITHUB_TOKEN")
    if token:
        headers["Authorization"] = f"Bearer {token}"

    request = urllib.request.Request(url, headers=headers)

    try:
        with urllib.request.urlopen(request) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8", errors="replace").strip()
        detail = f": {body}" if body else ""
        raise UpdateError(f"GitHub API request failed ({error.code}) for {url}{detail}") from error
    except urllib.error.URLError as error:
        raise UpdateError(f"GitHub API request failed for {url}: {error.reason}") from error
    except json.JSONDecodeError as error:
        raise UpdateError(f"GitHub API returned invalid JSON for {url}") from error


def github_repo_path(owner: str, repo: str) -> str:
    return f"repos/{urllib.parse.quote(owner, safe='')}/{urllib.parse.quote(repo, safe='')}"


def github_repo(owner: str, repo: str) -> dict[str, Any]:
    data = github_api_get_json(f"{GITHUB_API}/{github_repo_path(owner, repo)}")
    if not isinstance(data, dict):
        raise UpdateError(f"Unexpected GitHub repository metadata for {owner}/{repo}")
    return data


def github_repo_default_branch(owner: str, repo: str) -> str:
    branch = github_repo(owner, repo).get("default_branch")
    if not isinstance(branch, str) or not branch:
        raise UpdateError(f"Could not determine update branch for {owner}/{repo}")
    return branch


def github_branch_head(owner: str, repo: str, branch: str) -> str:
    quoted_branch = urllib.parse.quote(branch, safe="")
    url = f"{GITHUB_API}/{github_repo_path(owner, repo)}/commits/{quoted_branch}"
    data = github_api_get_json(url)

    if not isinstance(data, dict):
        raise UpdateError(f"Unexpected GitHub commit metadata for {owner}/{repo} branch {branch}")

    sha = data.get("sha")
    if not isinstance(sha, str) or not sha:
        raise UpdateError(f"Could not fetch latest commit for {owner}/{repo} branch {branch}")

    return sha


def read_text(file: Path) -> str:
    return file.read_text(encoding="utf-8")


def write_text(file: Path, text: str) -> None:
    file.write_text(text, encoding="utf-8")


def package_update_skip_reason(text: str) -> str | None:
    match = re.search(r"^# update-skip:[ \t]*(.*)$", text, flags=re.MULTILINE)
    return match.group(1) if match else None


def package_update_branch_override(text: str) -> str | None:
    match = re.search(r"^# update-branch:[ \t]*(.*)$", text, flags=re.MULTILINE)
    branch = match.group(1).strip() if match else ""
    return branch or None


def src_fetch_from_github_match(text: str) -> re.Match[str] | None:
    return re.search(r"src\s*=\s*fetchFromGitHub\s*\{(.*?)\};", text, flags=re.DOTALL)


def extract_src_fetch_from_github_field(text: str, file: Path, field: str) -> str:
    match = src_fetch_from_github_match(text)
    if not match:
        raise UpdateError(f"Cannot find src = fetchFromGitHub {{ ... }} in {file}")

    body = match.group(1)
    field_match = re.search(rf'\b{re.escape(field)}\s*=\s*"([^"]+)";', body)
    return field_match.group(1) if field_match else ""


def replace_in_src_fetch_from_github(
    text: str,
    file: Path,
    pattern: re.Pattern[str],
    replacement: str | Callable[[re.Match[str]], str],
) -> str:
    match = src_fetch_from_github_match(text)
    if not match:
        raise UpdateError(f"Cannot find src = fetchFromGitHub {{ ... }} in {file}")

    start, end = match.span(1)
    body = text[start:end]
    new_body, count = pattern.subn(replacement, body, count=1)

    if count == 0:
        raise UpdateError(f"Could not update src.fetchFromGitHub field in {file}")

    return f"{text[:start]}{new_body}{text[end:]}"


def replace_src_fetch_from_github_string_field(text: str, file: Path, field: str, value: str) -> str:
    pattern = re.compile(rf'(\b{re.escape(field)}\s*=\s*")[^"]+(";)')
    return replace_in_src_fetch_from_github(
        text,
        file,
        pattern,
        lambda match: f"{match.group(1)}{value}{match.group(2)}",
    )


def replace_src_fetch_from_github_hash_field(text: str, file: Path, value: str) -> str:
    pattern = re.compile(r'(\bhash\s*=\s*)("[^"]+"|lib\.fakeHash)(;)')

    def replacement(match: re.Match[str]) -> str:
        rendered_value = "lib.fakeHash" if value == "lib.fakeHash" else f'"{value}"'
        return f"{match.group(1)}{rendered_value}{match.group(3)}"

    return replace_in_src_fetch_from_github(text, file, pattern, replacement)


def assert_no_secondary_fake_hash(text: str, file: Path) -> None:
    match = re.search(r"zig\.fetchDeps\s*\{(.*?)\};", text, flags=re.DOTALL)
    if match and re.search(r"hash\s*=\s*lib\.fakeHash\s*;", match.group(1)):
        raise UpdateError(
            f"ERROR: zig.fetchDeps.hash was changed to lib.fakeHash in {file}\n"
            "This updater should only modify src.fetchFromGitHub.hash."
        )


def extract_got_hash_from_build_output(output: str) -> str:
    matches = re.findall(r"(?:got|actual):[ \t]*(sha256-[A-Za-z0-9+/=]+)", output)
    return matches[-1] if matches else ""


def update_src_hash_by_building(pkg: str, file: Path) -> None:
    print("==> Setting src.hash to lib.fakeHash")
    text = replace_src_fetch_from_github_hash_field(read_text(file), file, "lib.fakeHash")
    assert_no_secondary_fake_hash(text, file)
    write_text(file, text)

    print(f"==> Building .#{pkg} to get source hash")
    result = run(["nix", "build", f".#{pkg}"], capture=True, check=False, stderr_to_stdout=True)

    if result.returncode == 0:
        print("Build succeeded with lib.fakeHash; no source hash mismatch found.")
        return

    print(result.stdout, end="")
    new_hash = extract_got_hash_from_build_output(result.stdout)

    if not new_hash:
        raise UpdateError(
            "\nCould not extract new src hash from Nix output.\n"
            "You may need to update the hash manually."
        )

    print(f"==> New src.hash: {new_hash}")
    text = replace_src_fetch_from_github_hash_field(read_text(file), file, new_hash)
    assert_no_secondary_fake_hash(text, file)
    write_text(file, text)


def update_unstable_date_version(text: str, today: str) -> str:
    return re.sub(
        r'^([ \t]*)version[ \t]*=[ \t]*"0-unstable-\d{4}-\d{2}-\d{2}";[ \t]*$',
        rf'\1version = "0-unstable-{today}";',
        text,
        flags=re.MULTILINE,
    )


def update_one(pkg: str) -> None:
    file = package_file_for(pkg)

    print(f"==> Updating manual package: {pkg}")
    print(f"==> Package file: {file}")

    text = read_text(file)
    skip_reason = package_update_skip_reason(text)
    if skip_reason is not None:
        print(f"==> Skipping update: {skip_reason}")
        return

    owner = extract_src_fetch_from_github_field(text, file, "owner")
    repo = extract_src_fetch_from_github_field(text, file, "repo")
    old_rev = extract_src_fetch_from_github_field(text, file, "rev")

    if not owner or not repo:
        raise UpdateError(f"Cannot extract owner/repo from src = fetchFromGitHub {{ ... }} in {file}")

    if not old_rev:
        raise UpdateError(f"Cannot extract rev from src = fetchFromGitHub {{ ... }} in {file}")

    branch = package_update_branch_override(text)
    if branch:
        branch_source = "package override"
    else:
        branch = github_repo_default_branch(owner, repo)
        branch_source = "GitHub default"

    print(f"==> GitHub repo: {owner}/{repo}")
    print(f"==> Branch: {branch} ({branch_source})")
    print(f"==> Old rev: {old_rev}")

    new_rev = github_branch_head(owner, repo, branch)
    print(f"==> New rev: {new_rev}")

    if old_rev == new_rev:
        print(f"Already up to date: {pkg}")
    else:
        text = replace_src_fetch_from_github_string_field(read_text(file), file, "rev", new_rev)
        today = _datetime.datetime.now(tz=_datetime.timezone.utc).date().isoformat()
        text = update_unstable_date_version(text, today)
        write_text(file, text)
        update_src_hash_by_building(pkg, file)

    if BUILD_AFTER_UPDATE == "1":
        print(f"==> Final build .#{pkg}")
        result = run(["nix", "build", f".#{pkg}"], check=False)
        if result.returncode != 0:
            raise UpdateError(
                f"\nFinal build failed for manual package: {pkg}\n\n"
                "If this package has secondary fixed-output hashes, for example:\n"
                "  zig.fetchDeps.hash\n"
                "then update that hash manually or add a package-specific update hook."
            )

    diff_result = run(["git", "diff", "--quiet", "--", str(file), "flake.nix", "flake.lock"], check=False)
    if diff_result.returncode != 0:
        run(["git", "add", str(file), "flake.nix", "flake.lock"])

        if AUTO_COMMIT == "1":
            run(["git", "commit", "-m", f"manual-packages/{pkg}: update"])
    else:
        print(f"No changes for {pkg}")


def update_all() -> None:
    for pkg in manual_package_names():
        if pkg:
            update_one(pkg)


def main(argv: list[str]) -> int:
    os.chdir(repo_root())

    arg = argv[1] if len(argv) > 1 else "--all"
    if arg in ("-h", "--help"):
        print(usage(), end="")
        return 0

    if arg == "--all":
        update_all()
    else:
        update_one(arg)

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except UpdateError as error:
        print(error, file=sys.stderr)
        raise SystemExit(1)
    except subprocess.CalledProcessError as error:
        command = " ".join(error.cmd) if isinstance(error.cmd, list) else str(error.cmd)
        print(f"Command failed ({error.returncode}): {command}", file=sys.stderr)
        if error.stdout:
            print(error.stdout, file=sys.stderr, end="" if error.stdout.endswith("\n") else "\n")
        raise SystemExit(error.returncode)
