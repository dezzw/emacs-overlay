#!/usr/bin/env nix-shell
#! nix-shell -i bash -p bash git

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./update <repo>
  ./update manual
  ./update manual <package>
  ./update manual --all

Examples:
  ./update emacs
  ./update melpa
  ./update elpa
  ./update nongnu
  ./update fromElisp
EOF
}

repo="${1:-}"

case "$repo" in
  ""|-h|--help)
    usage
    exit 0
    ;;
esac

root="$(git rev-parse --show-toplevel)"
cd "$root"

shift

if [ "$repo" = "manual" ]; then
  exec ./manual-packages/update "$@"
fi

update_script="repos/$repo/update"

if [ ! -x "$update_script" ]; then
  echo "Unknown update target or non-executable update script: $repo" >&2
  echo >&2
  usage >&2
  exit 1
fi

"$update_script" "$@"

if git diff --exit-code "repos/$repo" > /dev/null; then
  exit 0
fi

git commit -m "Updated $repo" -- "repos/$repo"
