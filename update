#!/usr/bin/env nix-shell
#! nix-shell -i bash -p bash git

set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

target="${1:-}"

usage() {
  cat <<'EOF'
Usage:
  ./update emacs
  ./update melpa
  ./update elpa
  ./update nongnu
  ./update manual
  ./update manual <package>
  ./update manual --all
EOF
}

case "$target" in
  manual)
    shift
    exec ./manual-packages/update "$@"
    ;;

  emacs|melpa|elpa|nongnu)
    "repos/$target/update"

    if ! git diff --quiet -- "repos/$target"; then
      git add "repos/$target"
      git commit -m "repos/$target: update"
    else
      echo "No changes for repos/$target"
    fi
    ;;

  ""|-h|--help)
    usage
    ;;

  *)
    echo "Unknown update target: $target"
    echo
    usage
    exit 1
    ;;
esac
