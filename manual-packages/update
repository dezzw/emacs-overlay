#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

AUTO_COMMIT="${AUTO_COMMIT:-1}"
BUILD_AFTER_UPDATE="${BUILD_AFTER_UPDATE:-1}"
GITHUB_API="${GITHUB_API:-https://api.github.com}"

usage() {
  cat <<'EOF'
Usage:
  ./manual-packages/update
  ./manual-packages/update --all
  ./manual-packages/update <package>

Or from repo root:
  ./update manual
  ./update manual --all
  ./update manual <package>

Default:
  no argument means --all

Environment:
  AUTO_COMMIT=0          Do not commit changes
  BUILD_AFTER_UPDATE=0   Do not build after update
  GITHUB_TOKEN=...       Optional GitHub token for higher GitHub API rate limit

Per-package options:
  Add this comment near the top of a package file to override the default branch:

    # update-branch: master
EOF
}

manual_package_names() {
  local system
  system="$(nix eval --impure --raw --expr builtins.currentSystem)"

  nix eval --json ".#lib.${system}.manualPackageNames" | jq -r '.[]'
}

package_file_for() {
  local pkg="$1"

  if [ -f "manual-packages/${pkg}.nix" ]; then
    printf '%s\n' "manual-packages/${pkg}.nix"
  elif [ -f "manual-packages/${pkg}/package.nix" ]; then
    printf '%s\n' "manual-packages/${pkg}/package.nix"
  else
    echo "Cannot find package file for manual package: $pkg" >&2
    exit 1
  fi
}

github_api_get() {
  local url="$1"

  if [ -n "${GITHUB_TOKEN:-}" ]; then
    curl -fsSL \
      -H "Authorization: Bearer ${GITHUB_TOKEN}" \
      -H "Accept: application/vnd.github+json" \
      "$url"
  else
    curl -fsSL \
      -H "Accept: application/vnd.github+json" \
      "$url"
  fi
}

extract_src_fetch_from_github_field() {
  local file="$1"
  local field="$2"

  FIELD="$field" perl -0ne '
    my $field = $ENV{FIELD};

    if (/src\s*=\s*fetchFromGitHub\s*\{(.*?)\};/s) {
      my $body = $1;

      if ($body =~ /\b\Q$field\E\s*=\s*"([^"]+)";/) {
        print "$1\n";
      }
    }
  ' "$file" | head -n1
}

replace_src_fetch_from_github_string_field() {
  local file="$1"
  local field="$2"
  local value="$3"

  FIELD="$field" VALUE="$value" perl -0pi -e '
    my $field = $ENV{FIELD};
    my $value = $ENV{VALUE};

    s{
      (src\s*=\s*fetchFromGitHub\s*\{)
      (.*?)
      (\};)
    }{
      my ($open, $body, $close) = ($1, $2, $3);

      $body =~ s{
        (\b\Q$field\E\s*=\s*")[^"]+(";)
      }{$1$value$2}xs;

      "$open$body$close"
    }xes;
  ' "$file"
}

replace_src_fetch_from_github_hash_field() {
  local file="$1"
  local value="$2"

  VALUE="$value" perl -0pi -e '
    my $value = $ENV{VALUE};

    s{
      (src\s*=\s*fetchFromGitHub\s*\{)
      (.*?)
      (\};)
    }{
      my ($open, $body, $close) = ($1, $2, $3);

      if ($value eq "lib.fakeHash") {
        $body =~ s{
          (\bhash\s*=\s*)("[^"]+"|lib\.fakeHash)(;)
        }{$1lib.fakeHash$3}xs;
      } else {
        $body =~ s{
          (\bhash\s*=\s*)("[^"]+"|lib\.fakeHash)(;)
        }{$1"$value"$3}xs;
      }

      "$open$body$close"
    }xes;
  ' "$file"
}

set_src_hash_fake() {
  local file="$1"
  replace_src_fetch_from_github_hash_field "$file" "lib.fakeHash"
}

extract_got_hash_from_build_output() {
  sed -nE 's/.*(got|actual):[[:space:]]*(sha256-[A-Za-z0-9+\/=]+).*/\2/p' \
    | tail -n1
}

assert_no_secondary_fake_hash() {
  local file="$1"

  if perl -0ne '
    if (/zig\.fetchDeps\s*\{(.*?)\};/s) {
      my $body = $1;
      exit($body =~ /hash\s*=\s*lib\.fakeHash\s*;/ ? 0 : 1);
    }
    exit 1;
  ' "$file"; then
    echo "ERROR: zig.fetchDeps.hash was changed to lib.fakeHash in $file"
    echo "This updater should only modify src.fetchFromGitHub.hash."
    exit 1
  fi
}

update_src_hash_by_building() {
  local pkg="$1"
  local file="$2"

  echo "==> Setting src.hash to lib.fakeHash"
  set_src_hash_fake "$file"
  assert_no_secondary_fake_hash "$file"

  echo "==> Building .#$pkg to get source hash"

  set +e
  local output
  output="$(nix build ".#$pkg" 2>&1)"
  local status=$?
  set -e

  if [ "$status" -eq 0 ]; then
    echo "Build succeeded with lib.fakeHash; no source hash mismatch found."
    return 0
  fi

  printf '%s\n' "$output"

  local new_hash
  new_hash="$(printf '%s\n' "$output" | extract_got_hash_from_build_output)"

  if [ -z "$new_hash" ]; then
    echo
    echo "Could not extract new src hash from Nix output."
    echo "You may need to update the hash manually."
    exit 1
  fi

  echo "==> New src.hash: $new_hash"

  replace_src_fetch_from_github_hash_field "$file" "$new_hash"
  assert_no_secondary_fake_hash "$file"
}

update_unstable_date_version() {
  local file="$1"
  local today="$2"

  TODAY="$today" perl -0pi -e '
    my $today = $ENV{TODAY};

    s{
      ^([ \t]*)version[ \t]*=[ \t]*"0-unstable-\d{4}-\d{2}-\d{2}";[ \t]*$
    }{$1version = "0-unstable-$today";}mgx;
  ' "$file"
}

update_one() {
  local pkg="$1"
  local file
  file="$(package_file_for "$pkg")"

  echo "==> Updating manual package: $pkg"
  echo "==> Package file: $file"

  if sed -n 's/^# update-skip:[[:space:]]*//p' "$file" | grep -q .; then
    echo "==> Skipping update: $(sed -n 's/^# update-skip:[[:space:]]*//p' "$file" | head -n1)"
    return 0
  fi

  local owner repo old_rev branch new_rev today

  owner="$(extract_src_fetch_from_github_field "$file" "owner")"
  repo="$(extract_src_fetch_from_github_field "$file" "repo")"
  old_rev="$(extract_src_fetch_from_github_field "$file" "rev")"

  if [ -z "$owner" ] || [ -z "$repo" ]; then
    echo "Cannot extract owner/repo from src = fetchFromGitHub { ... } in $file"
    exit 1
  fi

  if [ -z "$old_rev" ]; then
    echo "Cannot extract rev from src = fetchFromGitHub { ... } in $file"
    exit 1
  fi

  branch="$(sed -n 's/^# update-branch:[[:space:]]*//p' "$file" | head -n1)"
  branch="${branch:-main}"

  echo "==> GitHub repo: $owner/$repo"
  echo "==> Branch: $branch"
  echo "==> Old rev: $old_rev"

  new_rev="$(
    github_api_get "${GITHUB_API}/repos/${owner}/${repo}/commits/${branch}" \
      | jq -r '.sha'
  )"

  if [ -z "$new_rev" ] || [ "$new_rev" = "null" ]; then
    echo "Could not fetch latest commit for $owner/$repo branch $branch"
    exit 1
  fi

  echo "==> New rev: $new_rev"

  if [ "$old_rev" = "$new_rev" ]; then
    echo "Already up to date: $pkg"
  else
    replace_src_fetch_from_github_string_field "$file" "rev" "$new_rev"

    today="$(date -u +%F)"
    update_unstable_date_version "$file" "$today"

    update_src_hash_by_building "$pkg" "$file"
  fi

  if [ "$BUILD_AFTER_UPDATE" = "1" ]; then
    echo "==> Final build .#$pkg"

    if ! nix build ".#$pkg"; then
      echo
      echo "Final build failed for manual package: $pkg"
      echo
      echo "If this package has secondary fixed-output hashes, for example:"
      echo "  zig.fetchDeps.hash"
      echo "then update that hash manually or add a package-specific update hook."
      exit 1
    fi
  fi

  if ! git diff --quiet -- "$file" flake.nix flake.lock; then
    git add "$file" flake.nix flake.lock

    if [ "$AUTO_COMMIT" = "1" ]; then
      git commit -m "manual-packages/$pkg: update"
    fi
  else
    echo "No changes for $pkg"
  fi
}

update_all() {
  manual_package_names | while read -r pkg; do
    [ -n "$pkg" ] && update_one "$pkg"
  done
}

case "${1:---all}" in
  --all)
    update_all
    ;;

  -h|--help)
    usage
    ;;

  *)
    update_one "$1"
    ;;
esac
